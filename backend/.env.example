NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgres://guardianmcp:guardianmcp_dev@localhost:5432/guardianmcp

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-at-least-32-characters-long-secret
JWT_REFRESH_SECRET=change-me-to-at-least-32-characters-long-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Frontend
FRONTEND_URL=http://localhost:5173

# AWS (optional in dev)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe (optional in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (optional in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@guardianmcp.dev
