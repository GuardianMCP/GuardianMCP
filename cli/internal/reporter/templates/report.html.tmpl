<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GuardianMCP Security Report</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#0f172a;color:#e2e8f0;line-height:1.6;padding:2rem}
.container{max-width:960px;margin:0 auto}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;padding-bottom:1rem;border-bottom:1px solid #334155}
.header h1{font-size:1.5rem;color:#f8fafc}
.header .meta{font-size:0.875rem;color:#94a3b8;text-align:right}
.summary-bar{display:flex;gap:1rem;margin-bottom:2rem;flex-wrap:wrap;align-items:center}
.score-circle{width:80px;height:80px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-direction:column;border:3px solid {{.ScoreColor}};flex-shrink:0}
.score-circle .num{font-size:1.5rem;font-weight:bold;color:{{.ScoreColor}}}
.score-circle .label{font-size:0.625rem;color:#94a3b8}
.pill{display:inline-flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;border-radius:9999px;font-size:0.875rem;font-weight:600}
.pill-critical{background:#dc262620;color:#dc2626;border:1px solid #dc262640}
.pill-high{background:#ea580c20;color:#ea580c;border:1px solid #ea580c40}
.pill-medium{background:#d9770620;color:#d97706;border:1px solid #d9770640}
.pill-low{background:#2563eb20;color:#2563eb;border:1px solid #2563eb40}
.pill-info{background:#6b728020;color:#6b7280;border:1px solid #6b728040}
.section{margin-bottom:2rem}
.section h2{font-size:1.125rem;margin-bottom:1rem;color:#f8fafc}
.finding{background:#1e293b;border-radius:0.5rem;padding:1rem;margin-bottom:0.75rem;border-left:4px solid}
.finding-critical{border-left-color:#dc2626}
.finding-high{border-left-color:#ea580c}
.finding-medium{border-left-color:#d97706}
.finding-low{border-left-color:#2563eb}
.finding-info{border-left-color:#6b7280}
.finding-header{display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem}
.badge{padding:0.125rem 0.5rem;border-radius:0.25rem;font-size:0.75rem;font-weight:700;text-transform:uppercase}
.badge-critical{background:#dc2626;color:#fff}
.badge-high{background:#ea580c;color:#fff}
.badge-medium{background:#d97706;color:#fff}
.badge-low{background:#2563eb;color:#fff}
.badge-info{background:#6b7280;color:#fff}
.finding-title{font-weight:600;color:#f8fafc}
.finding-file{font-size:0.875rem;color:#94a3b8;margin-bottom:0.5rem}
.finding-snippet{background:#0f172a;padding:0.75rem;border-radius:0.375rem;font-family:'Fira Code',monospace;font-size:0.8125rem;overflow-x:auto;margin-bottom:0.5rem;white-space:pre-wrap;color:#cbd5e1}
.finding-fix{font-size:0.875rem;color:#22d3ee}
.finding-refs{font-size:0.75rem;color:#64748b;margin-top:0.25rem}
.rules-table{width:100%;border-collapse:collapse}
.rules-table th,.rules-table td{padding:0.5rem 0.75rem;text-align:left;border-bottom:1px solid #334155;font-size:0.875rem}
.rules-table th{color:#94a3b8;font-weight:600}
.footer{text-align:center;padding-top:1.5rem;border-top:1px solid #334155;color:#64748b;font-size:0.8125rem}
details summary{cursor:pointer;user-select:none}
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <div>
      <h1>GuardianMCP Security Report</h1>
      <div style="color:#94a3b8;font-size:0.875rem;margin-top:0.25rem">{{.ScanPath}}</div>
    </div>
    <div class="meta">
      <div>{{.Date}}</div>
      <div>guardianmcp v{{.CLIVersion}}</div>
      <div>{{.FilesScanned}} files | {{.RulesChecked}} rules | {{.Duration}}</div>
    </div>
  </div>

  <div class="summary-bar">
    <div class="score-circle">
      <span class="num">{{.SecurityScore}}</span>
      <span class="label">{{.ScoreLabel}}</span>
    </div>
    {{if gt .Summary.Critical 0}}<span class="pill pill-critical">{{.Summary.Critical}} Critical</span>{{end}}
    {{if gt .Summary.High 0}}<span class="pill pill-high">{{.Summary.High}} High</span>{{end}}
    {{if gt .Summary.Medium 0}}<span class="pill pill-medium">{{.Summary.Medium}} Medium</span>{{end}}
    {{if gt .Summary.Low 0}}<span class="pill pill-low">{{.Summary.Low}} Low</span>{{end}}
    {{if gt .Summary.Info 0}}<span class="pill pill-info">{{.Summary.Info}} Info</span>{{end}}
  </div>

  {{if .Findings}}
  <div class="section">
    <h2>Findings</h2>
    {{range .Findings}}
    <div class="finding finding-{{lower (print .Severity)}}">
      <div class="finding-header">
        <span class="badge badge-{{lower (print .Severity)}}">{{.Severity}}</span>
        <span style="font-size:0.8125rem;color:#94a3b8">[{{.RuleID}}]</span>
        <span class="finding-title">{{.RuleName}}</span>
      </div>
      <div class="finding-file">{{.File}}:{{.Line}}</div>
      {{if .Snippet}}
      <details>
        <summary style="font-size:0.8125rem;color:#64748b;margin-bottom:0.5rem">Show code</summary>
        <div class="finding-snippet">{{trimSnippet .Snippet}}</div>
      </details>
      {{end}}
      <div style="font-size:0.875rem;color:#cbd5e1;margin-bottom:0.375rem">{{.Message}}</div>
      {{if .Remediation}}<div class="finding-fix">Fix: {{.Remediation}}</div>{{end}}
      {{if or .CVERefs .OWASPRefs}}
      <div class="finding-refs">
        {{range .CVERefs}}{{.}} {{end}}{{range .OWASPRefs}}{{.}} {{end}}
      </div>
      {{end}}
    </div>
    {{end}}
  </div>
  {{else}}
  <div class="section">
    <h2>No findings detected</h2>
    <p style="color:#94a3b8">Your MCP server codebase passed all security checks.</p>
  </div>
  {{end}}

  {{if .RuleSummary}}
  <div class="section">
    <h2>Rules Summary</h2>
    <table class="rules-table">
      <thead><tr><th>Rule</th><th>Name</th><th>Severity</th><th>Findings</th></tr></thead>
      <tbody>
      {{range .RuleSummary}}
      <tr>
        <td>{{.RuleID}}</td>
        <td>{{.RuleName}}</td>
        <td><span class="badge badge-{{lower (print .Severity)}}">{{.Severity}}</span></td>
        <td>{{.Count}}</td>
      </tr>
      {{end}}
      </tbody>
    </table>
  </div>
  {{end}}

  <div class="footer">
    Generated by GuardianMCP &mdash; guardianmcp.dev
  </div>
</div>
</body>
</html>
